<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - ĐeSlavimo</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    <nav class="custom-navbar">
        <div class="custom-navbar-brand">
            @Html.ActionLink("ĐeSlavimo", "Index", "Home")
        </div>

        <div class="custom-navbar-links">
            @Html.ActionLink("Početna", "Index", "Home")
            @Html.ActionLink("Prostori", "Index", "Prostori")
            @Html.ActionLink("Detaljna pretraga", "DetaljnaPretraga", "Prostori")
            @Html.ActionLink("Preporuka prostora", "Index", "Preporuka")

            @if (Session["id_korisnika"] != null)
            {
                if (Session["uloga"] != null && Session["uloga"].ToString() == "Admin")
                {
                    @Html.ActionLink("Admin rezervacije", "SveRezervacije", "Rezervacije")
                    @Html.ActionLink("Admin paketi", "Index", "Paketi")
                    @Html.ActionLink("Admin komentari", "AdminKomentari", "Komentari")
                }
                else
                {
                    @Html.ActionLink("Moje rezervacije", "MojeRezervacije", "Rezervacije")
                    @Html.ActionLink("Omiljeni", "MojiOmiljeni", "OmiljeniProstori")
                }

                @Html.ActionLink("Odjava", "Logout", "Korisnici")
            }
            else
            {
                @Html.ActionLink("Prijava", "Login", "Korisnici", null, new { @class = "login-menu-link" })
                @Html.ActionLink("Registracija", "Register", "Korisnici")
            }
        </div>
    </nav>

    <div class="body-content">
        @RenderBody()

        <footer class="footer">
            <p>&copy; @DateTime.Now.Year - ĐeSlavimo</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>