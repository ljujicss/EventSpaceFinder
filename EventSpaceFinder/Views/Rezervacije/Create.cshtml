@{
    ViewBag.Title = "Zakazivanje prostora";
}

<div class="reservation-create-page">
    <div class="reservation-create-card">
        <p class="section-small">REZERVACIJA PROSTORA</p>

        <h2>Zakazivanje prostora</h2>

        <p class="reservation-create-text">
            Popunite podatke za rezervaciju prostora
            <b>@ViewBag.naziv_prostora</b>.
        </p>

        @using (Html.BeginForm("Create", "Rezervacije", FormMethod.Post))
        {
            <input type="hidden" name="id_prostora" value="@ViewBag.id_prostora" />

            <div class="form-group">
                <label>Paket</label>
                @Html.DropDownList("id_paketa", null, "Izaberite paket", new { @class = "form-control", required = "required" })
            </div>

            <div class="form-group">
                <label>Datum događaja</label>
                <input type="date" name="datum_dogadjaja" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Broj gostiju</label>
                <input type="number" name="broj_gostiju" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Napomena</label>
                <textarea name="napomena" class="form-control reservation-textarea" placeholder="Unesite dodatne želje ili napomenu..."></textarea>
            </div>

            <button type="submit" class="btn btn-auth">
                Pošalji upit za rezervaciju
            </button>

            <div class="reservation-back-link">
                @Html.ActionLink("Nazad na prostore", "Index", "Prostori")
            </div>
        }
    </div>
</div>