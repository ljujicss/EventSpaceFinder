@model EventSpaceFinder.Prostor
@using System.Linq

@{
    ViewBag.Title = "Detalji prostora";

    var glavnaSlika = Model.SlikaProstoras.FirstOrDefault(s => s.glavna_slika == true);
}

<div class="details-hero">
    @if (glavnaSlika != null)
    {
        <img src="@glavnaSlika.putanja_slike" alt="@Model.naziv" />
    }
    else
    {
        <div class="details-no-image">Nema slike</div>
    }

    <div class="details-hero-text">
        <p class="section-small">DETALJI PROSTORA</p>
        <h1>@Model.naziv</h1>
        <p>@Model.Grad.naziv_grada · @Model.tip_prostora</p>
    </div>
</div>

<div class="details-page">
    <div class="details-main">
        <h2>@Model.naziv</h2>

        <p class="details-description">
            @Model.opis
        </p>

        <div class="details-info-grid">
            <div class="details-info-box">
                <span>Grad</span>
                <b>@Model.Grad.naziv_grada</b>
            </div>

            <div class="details-info-box">
                <span>Adresa</span>
                <b>@Model.adresa</b>
            </div>

            <div class="details-info-box">
                <span>Kapacitet</span>
                <b>@Model.kapacitet gostiju</b>
            </div>

            <div class="details-info-box">
                <span>Osnovna cijena</span>
                <b>@Model.osnovna_cijena €</b>
            </div>
        </div>

        <hr />

        <h3>Galerija prostora</h3>

        @{
            var sporedneSlike = Model.SlikaProstoras
                .Where(s => s.glavna_slika == false)
                .GroupBy(s => s.putanja_slike)
                .Select(g => g.First())
                .ToList();
        }

        @if (sporedneSlike != null && sporedneSlike.Any())
        {
            <div class="details-gallery">
                @foreach (var slika in sporedneSlike)
                {
                    <div class="gallery-item">
                        <img src="@slika.putanja_slike" alt="@Model.naziv" />
                    </div>
                }
            </div>
        }
        else
        {
            <p>Nema dodatih sporednih slika za ovaj prostor.</p>
        }

        <hr />

        <h3>Ocjene</h3>

        @if (Model.Ocjenas != null && Model.Ocjenas.Any())
        {
            decimal suma = 0;
            int broj = 0;

            foreach (var o in Model.Ocjenas)
            {
                suma = suma + o.ocjena1;
                broj++;
            }

            decimal prosjek = suma / broj;

            <div class="rating-box">
                <h4>@prosjek.ToString("0.00") / 5</h4>
                <p>Broj ocjena: @broj</p>
            </div>
        }
        else
        {
            <p>Ovaj prostor još nema ocjena.</p>
        }

        <div class="details-form-box">
            <h4>Dodaj ocjenu</h4>

            @using (Html.BeginForm("Create", "Ocjene", FormMethod.Post))
            {
                <input type="hidden" name="id_prostora" value="@Model.id_prostora" />

                <div class="form-group">
                    <label>Ocjena</label>
                    <select name="ocjena" class="form-control" required>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">Sačuvaj ocjenu</button>
            }
        </div>

        
        <hr />

        <h3>Komentari</h3>

        @if (Model.Komentars != null && Model.Komentars.Any(k => k.odobren == true))
        {
            foreach (var komentar in Model.Komentars.Where(k => k.odobren == true))
            {
                <div class="comment-box">
                    <p>@komentar.tekst_komentara</p>

                    <small>
                        @komentar.Korisnik.ime @komentar.Korisnik.prezime,
                        @komentar.datum_komentara.ToString("dd.MM.yyyy")
                    </small>

                    <br />
                    <br />

                    @if (Session["uloga"] != null && Session["uloga"].ToString() == "Admin")
                    {
                        using (Html.BeginForm("Delete", "Komentari", FormMethod.Post))
                        {
                            <input type="hidden" name="id_komentara" value="@komentar.id_komentara" />
                            <input type="hidden" name="id_prostora" value="@Model.id_prostora" />

                            <button type="submit" class="btn btn-delete-soft btn-sm">Obriši</button>
                        }
                    }
                </div>
            }
        }
        else
        {
            <p>Nema komentara za ovaj prostor.</p>
        }

    <div class="details-form-box">
        <h4>Dodaj komentar</h4>

        @using (Html.BeginForm("Create", "Komentari", FormMethod.Post))
        {
            <input type="hidden" name="id_prostora" value="@Model.id_prostora" />

            <div class="form-group">
                <label>Komentar</label>
                <textarea name="tekst_komentara" class="form-control comment-textarea" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Sačuvaj komentar</button>
        }
    </div>
    </div>

    <div class="details-sidebar">
        <div class="sidebar-card">
            <h3>Rezervacija</h3>

            <p>
                Sviđa vam se ovaj prostor? Pošaljite zahtjev za rezervaciju i pratite status u aplikaciji.
            </p>

            @Html.ActionLink("Zakaži prostor", "Create", "Rezervacije", new { id_prostora = Model.id_prostora }, new { @class = "btn btn-dark-full" })

            <br />

            @if (Session["id_korisnika"] != null)
            {
                int idKorisnika = Convert.ToInt32(Session["id_korisnika"]);
                bool vecJeOmiljeni = Model.OmiljeniProstors.Any(o => o.id_korisnika == idKorisnika);

                if (!vecJeOmiljeni)
                {
                    using (Html.BeginForm("Dodaj", "OmiljeniProstori", FormMethod.Post))
                    {
                        <input type="hidden" name="id_prostora" value="@Model.id_prostora" />
                        <button type="submit" class="btn btn-outline-full">Dodaj u omiljene</button>
                    }
                }
                else
                {
                    using (Html.BeginForm("Ukloni", "OmiljeniProstori", FormMethod.Post))
                    {
                        <input type="hidden" name="id_prostora" value="@Model.id_prostora" />
                        <button type="submit" class="btn btn-outline-full">Ukloni iz omiljenih</button>
                    }
                }
            }
            else
            {
                @Html.ActionLink("Prijavite se za omiljene", "Login", "Korisnici", null, new { @class = "btn btn-outline-full" })
            }

            <br />

            @Html.ActionLink("Nazad na listu", "Index", null, new { @class = "btn btn-default" })
        </div>
    </div>
</div>