@model IEnumerable<EventSpaceFinder.Prostor>
@using System.Linq

@{
    ViewBag.Title = "Prostori";
}

<div class="page-header-section">
    <p class="section-small">PREGLED PROSTORA</p>
    <h2>Pronađite prostor za svoju proslavu</h2>
    <p>Pretražite restorane, hotele, vile i sale za svadbe, rođendane, mature i druge događaje.</p>
</div>

<div class="search-section">
    @using (Html.BeginForm("Index", "Prostori", FormMethod.Get))
    {
        <div class="search-box-simple">
            <input type="text" name="search" class="form-control" placeholder="Pretraži po nazivu, gradu, adresi..." value="@ViewBag.Search" />
            <button type="submit" class="btn btn-primary">Pretraži</button>
        </div>
    }
</div>

@if (Session["uloga"] != null && Session["uloga"].ToString() == "Admin")
{
    <div class="admin-add-button">
        @Html.ActionLink("Dodaj novi prostor", "Create", null, new { @class = "btn btn-success" })
    </div>
}

<div class="venues-grid">
    @foreach (var item in Model.Where(p => p.aktivan == true))
    {
        var glavnaSlika = item.SlikaProstoras.FirstOrDefault(s => s.glavna_slika == true);

        <div class="venue-card">
            <a href="@Url.Action("Details", "Prostori", new { id = item.id_prostora })" class="venue-image-link">
                @if (glavnaSlika != null)
                {
                    <img src="@glavnaSlika.putanja_slike" alt="@item.naziv" />
                }
                else
                {
                    <div class="no-image">Nema slike</div>
                }
            </a>
            <div class="venue-card-body">
                <h3>@item.naziv</h3>

                <p class="venue-location">
                    @item.Grad.naziv_grada
                </p>

                <p class="venue-description">
                    @item.opis
                </p>

                <div class="venue-info">
                    <span>Kapacitet: @item.kapacitet</span>
                    <span>Cijena: @item.osnovna_cijena €</span>
                </div>

                <div class="venue-actions">
                    @Html.ActionLink("Detalji", "Details", new { id = item.id_prostora }, new { @class = "btn btn-info btn-sm" })

                    @if (Session["uloga"] != null && Session["uloga"].ToString() == "Admin")
                    {
                        @Html.ActionLink("Izmijeni", "Edit", new { id = item.id_prostora }, new { @class = "btn btn-warning btn-sm" })
                        @Html.ActionLink("Obriši", "Delete", new { id = item.id_prostora }, new { @class = "btn btn-danger btn-sm" })
                    }
                </div>
            </div>
        </div>
    }
</div>