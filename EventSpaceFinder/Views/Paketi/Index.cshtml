@model IEnumerable<EventSpaceFinder.Paket>

@{
    ViewBag.Title = "Admin paketi";
}

<div class="admin-packages-page">
    <div class="admin-packages-header">
        <p class="section-small">ADMIN PANEL</p>

        <h2>Paketi prostora</h2>

        <p>
            Pregled i uređivanje paketa koji se nude uz prostore za proslave.
        </p>
    </div>

    <div class="admin-add-button packages-add-button">
        @Html.ActionLink("Dodaj novi paket", "Create", null, new { @class = "btn btn-dark-full" })
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="packages-grid">
            @foreach (var item in Model)
            {
                <div class="package-card">
                    <div class="package-card-header">
                        <h3>@item.naziv_paketa</h3>

                        @if (item.aktivan)
                        {
                            <span class="package-status package-active">Aktivan</span>
                        }
                        else
                        {
                            <span class="package-status package-inactive">Neaktivan</span>
                        }
                    </div>

                    <p class="package-place">
                        @item.Prostor.naziv
                    </p>

                    <p class="package-description">
                        @item.opis
                    </p>

                    <div class="package-info">
                        <p><b>Cijena:</b> @item.cijena €</p>
                        <p><b>Broj sati:</b> @item.broj_sati</p>
                    </div>

                    <div class="package-actions">
                        @Html.ActionLink("Izmijeni", "Edit", new { id = item.id_paketa }, new { @class = "btn btn-outline-full" })
                        @Html.ActionLink("Detalji", "Details", new { id = item.id_paketa }, new { @class = "btn btn-dark-full" })
                        @Html.ActionLink("Obriši", "Delete", new { id = item.id_paketa }, new { @class = "btn btn-delete-soft package-delete-button" })
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-message-box">
            <h3>Nema paketa.</h3>
            <p>Trenutno nema dodatih paketa za prostore.</p>
        </div>
    }
</div>