@model IEnumerable<EventSpaceFinder.Komentar>

@{
    ViewBag.Title = "Admin komentari";
}

<div class="admin-comments-page">
    <div class="admin-comments-header">
        <p class="section-small">ADMIN PANEL</p>

        <h2>Admin komentari</h2>

        <p>
            Pregled komentara korisnika, odobravanje, sakrivanje i brisanje komentara.
        </p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="admin-comments-list">
            @foreach (var item in Model)
            {
                <div class="admin-comment-card">
                    <div class="admin-comment-main">
                        <h3>@item.Prostor.naziv</h3>

                        <p class="comment-user">
                            @item.Korisnik.ime @item.Korisnik.prezime · @item.datum_komentara.ToString("dd.MM.yyyy")
                        </p>

                        <p class="comment-text">
                            @item.tekst_komentara
                        </p>

                        @if (item.odobren)
                        {
                            <span class="comment-status comment-approved">Odobren</span>
                        }
                        else
                        {
                            <span class="comment-status comment-hidden">Nije odobren</span>
                        }
                    </div>

                    <div class="admin-comment-actions">
                        @using (Html.BeginForm("PromijeniOdobren", "Komentari", FormMethod.Post))
                        {
                            <input type="hidden" name="id_komentara" value="@item.id_komentara" />

                            if (item.odobren)
                            {
                                <button type="submit" class="btn btn-outline-full">Sakrij komentar</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-dark-full">Odobri komentar</button>
                            }
                        }

                        @using (Html.BeginForm("AdminDelete", "Komentari", FormMethod.Post))
                        {
                            <input type="hidden" name="id_komentara" value="@item.id_komentara" />
                            <button type="submit" class="btn btn-delete-soft admin-delete-button">Obriši komentar</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-message-box">
            <h3>Nema komentara.</h3>
            <p>Trenutno nema komentara za prikaz.</p>
        </div>
    }
</div>