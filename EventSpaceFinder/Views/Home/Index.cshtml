@{
    ViewBag.Title = "Početna";
}

<div class="hero">
    <div class="hero-content">
        <p class="hero-small">Sva mjesta za jedno</p>

        <h1>ĐE SLAVIMO?</h1>

        <h2>
            Kreiraj uspomene na
            <span>savršenom mjestu</span>
        </h2>

        <p class="hero-text">
            Od romantičnih vjenčanja pod svijećama do urbanih proslava iznad grada —
            pronađite i rezervišite prostor dostojan vašeg trenutka.
        </p>

        <div class="hero-search">
            @using (Html.BeginForm("Index", "Prostori", FormMethod.Get))
            {
                <div class="search-field">
                    <label>Lokacija</label>
                    <input type="text" name="search" placeholder="Grad ili prostor" />
                </div>

                <div class="search-field">
                    <label>Datum</label>
                    <input type="date" name="datum" />
                </div>

                <div class="search-field">
                    <label>Gosti</label>
                    <input type="number" name="broj_gostiju" placeholder="Broj gostiju" />
                </div>

                <button type="submit">Pretraži</button>
            }
        </div>

        <div class="hero-buttons">
            @Html.ActionLink("Pogledaj prostore", "Index", "Prostori", null, new { @class = "btn btn-gold" })
            @Html.ActionLink("Preporuka prostora", "Index", "Preporuka", null, new { @class = "btn btn-light-outline" })
        </div>
    </div>
</div>

<div class="home-section">
    <p class="section-small">Za svaku priliku</p>

    <style>
        .occasion-stickers-section {
            background-color: #fbf7ef;
            padding: 45px 8% 70px 8%;
        }

        .occasion-stickers-header {
            max-width: 900px;
            margin-bottom: 35px;
        }

            .occasion-stickers-header h2 {
                color: #0b2f22;
                font-size: 46px;
                margin-top: 10px;
                margin-bottom: 10px;
            }

            .occasion-stickers-header p {
                color: #5f6b66;
                line-height: 1.7;
                max-width: 650px;
            }

        .occasion-stickers-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 16px;
        }

        .occasion-sticker {
            background-color: white;
            border: 1px solid #eadfce;
            border-radius: 14px;
            padding: 22px 15px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }

            .occasion-sticker:hover {
                transform: translateY(-4px);
                box-shadow: 0 14px 30px rgba(0,0,0,0.08);
            }

        .occasion-icon {
            font-size: 32px;
            display: block;
            margin-bottom: 12px;
        }

        .occasion-sticker h3 {
            color: #0b2f22;
            font-size: 22px;
            margin: 0;
        }

        .occasion-sticker p {
            color: #5f6b66;
            font-size: 14px;
            margin-top: 8px;
            margin-bottom: 0;
        }

        .home-contact-section {
            background-color: #fbf7ef;
            padding: 80px 8%;
        }

        .home-contact-box {
            background-color: #0b2f22;
            color: white;
            border-radius: 18px;
            padding: 55px;
            display: flex;
            justify-content: space-between;
            gap: 50px;
            box-shadow: 0 18px 40px rgba(0,0,0,0.16);
        }

        .home-contact-left {
            flex: 1.3;
        }

            .home-contact-left h2 {
                font-size: 46px;
                margin-top: 10px;
                margin-bottom: 18px;
                color: white;
            }

            .home-contact-left p {
                color: rgba(255,255,255,0.82);
                line-height: 1.8;
                max-width: 620px;
            }

        .home-contact-right {
            flex: 1;
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .contact-item {
            background-color: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 12px;
            padding: 18px;
        }

            .contact-item span {
                display: block;
                color: #c99a3d;
                text-transform: uppercase;
                letter-spacing: 2px;
                font-size: 12px;
                margin-bottom: 7px;
                font-weight: bold;
            }

            .contact-item p {
                margin: 0;
                color: white;
                font-size: 17px;
            }

        @@media (max-width: 1100px) {
            .occasion-stickers-grid {
                grid-template-columns: repeat(3, 1fr);
            }

            .home-contact-box {
                flex-direction: column;
            }
        }

        @@media (max-width: 700px) {
            .occasion-stickers-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .occasion-stickers-header h2,
            .home-contact-left h2 {
                font-size: 34px;
            }

            .home-contact-box {
                padding: 35px 25px;
            }
        }
    </style>

    <section class="occasion-stickers-section">
        <div class="occasion-stickers-header">
            

            <h2>Svaka proslava ima svoje mjesto</h2>

            <p>
                Od elegantnih svadbi i rođendana do matura, poslovnih događaja i privatnih proslava —
                pronađite prostor koji odgovara vašem trenutku.
            </p>
        </div>

        <div class="occasion-stickers-grid">
            <div class="occasion-sticker">
                <span class="occasion-icon">💍</span>
                <h3>Svadbe</h3>
                <p>Svečani prostori za poseban dan.</p>
            </div>

            <div class="occasion-sticker">
                <span class="occasion-icon">🎂</span>
                <h3>Rođendani</h3>
                <p>Male i velike rođendanske proslave.</p>
            </div>

            <div class="occasion-sticker">
                <span class="occasion-icon">🎓</span>
                <h3>Mature</h3>
                <p>Prostori za mature i apsolventske večeri.</p>
            </div>

            <div class="occasion-sticker">
                <span class="occasion-icon">💼</span>
                <h3>Poslovno</h3>
                <p>Konferencije, kokteli i poslovne večere.</p>
            </div>

            <div class="occasion-sticker">
                <span class="occasion-icon">🥂</span>
                <h3>Privatno</h3>
                <p>Intimne proslave i posebni trenuci.</p>
            </div>

            <div class="occasion-sticker">
                <span class="occasion-icon">🌿</span>
                <h3>Na otvorenom</h3>
                <p>Bašte, terase i prostori pod nebom.</p>
            </div>
        </div>
    </section>
</div>

<div class="steps-section">
    <div class="steps-left">
        <p class="section-small">Započnite planiranje</p>

        <h2>Recite nam nešto o vašoj proslavi</h2>

        <p>
            Unesite osnovne podatke, a ĐeSlavimo će vam pomoći da pronađete prostor
            koji odgovara vašem događaju, broju gostiju, budžetu i datumu.
        </p>

        <div class="step">
            <span>01</span>
            <div>
                <h4>Odaberite tip događaja</h4>
                <p>Svadba, rođendan, matura, krštenje ili poslovni događaj.</p>
            </div>
        </div>

        <div class="step">
            <span>02</span>
            <div>
                <h4>Pronađite prostor</h4>
                <p>Pretražite prostore ili koristite preporuku najboljeg prostora.</p>
            </div>
        </div>

        <div class="step">
            <span>03</span>
            <div>
                <h4>Rezervišite termin</h4>
                <p>Pošaljite zahtjev i pratite status rezervacije.</p>
            </div>
        </div>
    </div>

    <div class="steps-right">
        <div class="info-card">
            <h3>Pronađite prostor po mjeri</h3>
            <p>
                Koristite preporuku prostora i pronađite najbolju opciju prema gradu,
                broju gostiju, budžetu i datumu.
            </p>

            @Html.ActionLink("Preporuka prostora", "Index", "Preporuka", null, new { @class = "btn btn-dark-full" })
            @Html.ActionLink("Pogledaj sve prostore", "Index", "Prostori", null, new { @class = "btn btn-outline-full" })
        </div>
    </div>


</div>

<section class="home-contact-section">
    <div class="home-contact-box">
        <div class="home-contact-left">
            <p class="section-small">KONTAKT</p>

            <h2>Treba vam pomoć oko izbora prostora?</h2>

            <p>
                Ako nijeste sigurni koji prostor najbolje odgovara vašoj proslavi,
                kontaktirajte nas i pomoći ćemo vam da pronađete mjesto koje se uklapa
                u broj gostiju, budžet i tip događaja.
            </p>
        </div>

        <div class="home-contact-right">
            <div class="contact-item">
                <span>Email</span>
                <p>info@djeslavimo.me</p>
            </div>

            <div class="contact-item">
                <span>Telefon</span>
                <p>+382 67 581 406</p>
            </div>

            <div class="contact-item">
                <span>Lokacija</span>
                <p>Podgorica, Crna Gora</p>
            </div>
        </div>
    </div>
</section>