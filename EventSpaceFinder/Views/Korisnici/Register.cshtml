@{
    ViewBag.Title = "Registracija";
}

<h2>Registracija</h2>

@if (ViewBag.Poruka != null)
{
    <div class="alert alert-danger">
        @ViewBag.Poruka
    </div>
}

@using (Html.BeginForm("Register", "Korisnici", FormMethod.Post))
{
    <div class="form-group">
        <label>Ime</label>
        <input type="text" name="ime" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Prezime</label>
        <input type="text" name="prezime" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Lozinka</label>
        <input type="password" name="lozinka" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Telefon</label>
        <input type="text" name="telefon" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Registruj se</button>
    @Html.ActionLink("Već imam nalog", "Login", "Korisnici", null, new { @class = "btn btn-default" })
}