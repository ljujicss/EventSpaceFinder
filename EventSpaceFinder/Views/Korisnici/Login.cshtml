@{
    ViewBag.Title = "Prijava";
}

<h2>Prijava</h2>

@if (ViewBag.Poruka != null)
{
    <div class="alert alert-danger">
        @ViewBag.Poruka
    </div>
}

@using (Html.BeginForm("Login", "Korisnici", FormMethod.Post))
{
    <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Lozinka</label>
        <input type="password" name="lozinka" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-primary">Prijavi se</button>
    @Html.ActionLink("Registracija", "Register", "Korisnici", null, new { @class = "btn btn-default" })
}