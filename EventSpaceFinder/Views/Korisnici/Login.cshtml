@{
    ViewBag.Title = "Prijava";
}

<div class="auth-page">
    <div class="auth-card">
        <p class="section-small">DOBRO DOŠLI NAZAD</p>

        <h2>Prijava</h2>

        <p class="auth-text">
            Prijavi se i rezerviši svoj prostor.
        </p>

        @if (ViewBag.Poruka != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Poruka
            </div>
        }

        @using (Html.BeginForm("Login", "Korisnici", FormMethod.Post))
        {
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>

            <div class="form-group">
                <label>Lozinka</label>
                <input type="password" name="lozinka" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-auth">Prijavi se</button>

            <p class="auth-link-text">
                Nemate nalog?
                @Html.ActionLink("Registrujte se", "Register", "Korisnici")
            </p>
        }
    </div>
</div>